# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Tavily
TAVILY_API_KEY=tvly-...

# Trello
TRELLO_API_KEY=...
TRELLO_TOKEN=...
TRELLO_OLD_BOARD_ID=...
TRELLO_NEW_BOARD_ID=...
TRELLO_NEW_LIST_ID=...

# Webshare residential proxies — get from https://dashboard.webshare.io
# CRITICAL: use the rotating residential tier; static residential and datacenter
# both fail because YouTube fingerprints the (cookie, IP) pair.
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=
WEBSHARE_HOST=p.webshare.io
WEBSHARE_PORT=80
WEBSHARE_SESSION_MIN=2
WEBSHARE_SESSION_MAX=499

# Server
PIPELINE_HOST=127.0.0.1
PIPELINE_PORT=8765
PIPELINE_DATA_DIR=./data
PIPELINE_LOG_LEVEL=INFO

# Optional: override default config-table values at first startup
PIPELINE_SCHEDULE_CRON=0 20 * * *
PIPELINE_LOOKBACK_HOURS=24
