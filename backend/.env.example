# Anthropic — REQUIRED. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Tavily — REQUIRED. Get a key at https://tavily.com (free tier is plenty).
TAVILY_API_KEY=

# Trello — REQUIRED. Key + token from https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=
# Board / list IDs are 24-char hex (you can find them in the board URL).
# Leave BLANK to auto-discover by name on first push, or to skip the dedup
# pre-cache. Do NOT put '...' or any non-hex placeholder here — bogus IDs
# will be rejected at startup.
TRELLO_OLD_BOARD_ID=
TRELLO_NEW_BOARD_ID=
TRELLO_NEW_LIST_ID=

# Webshare residential proxies — get from https://dashboard.webshare.io
# CRITICAL: use the rotating residential tier; static residential and datacenter
# both fail because YouTube fingerprints the (cookie, IP) pair.
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=
WEBSHARE_HOST=p.webshare.io
WEBSHARE_PORT=80
WEBSHARE_SESSION_MIN=2
WEBSHARE_SESSION_MAX=499

# Server
PIPELINE_HOST=127.0.0.1
PIPELINE_PORT=8765
PIPELINE_DATA_DIR=./data
PIPELINE_LOG_LEVEL=INFO

# Optional: override default config-table values at first startup
PIPELINE_SCHEDULE_CRON=0 20 * * *
PIPELINE_LOOKBACK_HOURS=24
